QUERY PLAN [
    CO-ROUTINE a0 [
        SCAN f0,
        SEARCH j0 USING INDEX invoice_index_0 (customer=?),
    ],
    MATERIALIZE a1 [
        CO-ROUTINE a0 [
            SCAN f0,
            SEARCH j0 USING INDEX invoice_index_0 (customer=?),
        ],
        SCAN f0,
        SEARCH j0 USING INDEX invoice_index_0 (customer=?),
        BLOOM FILTER ON a0 (f0=?),
        SEARCH a0 USING AUTOMATIC COVERING INDEX (f0=?),
    ],
    SCAN a0,
    SEARCH j0 USING INTEGER PRIMARY KEY (rowid=?),
    BLOOM FILTER ON a1 (f0=?),
    SEARCH a1 USING AUTOMATIC PARTIAL COVERING INDEX (f0=?),
]
