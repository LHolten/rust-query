QUERY PLAN [
    CO-ROUTINE a0 [
        SCAN f0,
        SEARCH j0 USING INDEX invoice_index_0 (customer=?),
    ],
    MATERIALIZE a1 [
        CO-ROUTINE a0 [
            SCAN f0,
            SEARCH j0 USING INDEX invoice_index_0 (customer=?),
        ],
        SCAN f0,
        SEARCH j0 USING INDEX invoice_index_0 (customer=?),
        BLOOM FILTER ON a0 (ff0=?),
        SEARCH a0 USING AUTOMATIC COVERING INDEX (ff0=?),
    ],
    SCAN a0,
    SEARCH j0 USING INTEGER PRIMARY KEY (rowid=?),
    BLOOM FILTER ON a1 (ff0=?),
    SEARCH a1 USING AUTOMATIC COVERING INDEX (ff0=?) LEFT-JOIN,
]
