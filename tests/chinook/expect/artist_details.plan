QUERY PLAN [
    CO-ROUTINE (subquery-1) [
        SCAN CONSTANT ROW,
    ],
    MATERIALIZE a0 [
        USE TEMP B-TREE FOR count(DISTINCT),
        SEARCH j0 USING COVERING INDEX album_index_0 (artist=?),
    ],
    MATERIALIZE a1 [
        USE TEMP B-TREE FOR count(DISTINCT),
        SEARCH j0 USING COVERING INDEX album_index_0 (artist=?),
        SEARCH j1 USING INDEX track_index_0 (album=?),
    ],
    SCAN (subquery-1),
    SEARCH u0 USING INTEGER PRIMARY KEY (rowid=?) LEFT-JOIN,
    SCAN a0 LEFT-JOIN,
    SCAN a1 LEFT-JOIN,
]
