QUERY PLAN [
    MATERIALIZE a0 [
        MATERIALIZE a0 [
            SCAN f0,
            SEARCH j0 USING COVERING INDEX track_index_0 (album=?),
        ],
        SCAN f0,
        SEARCH j0 USING COVERING INDEX album_index_0 (artist=?),
        BLOOM FILTER ON a0 (f0=?),
        SEARCH a0 USING AUTOMATIC COVERING INDEX (f0=?) LEFT-JOIN,
    ],
    SCAN j0,
    BLOOM FILTER ON a0 (f0=?),
    SEARCH a0 USING AUTOMATIC COVERING INDEX (f0=?) LEFT-JOIN,
]
